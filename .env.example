# APP_URL: The URL where this app is hosted.
APP_URL="http://localhost:3000"

# PORT: Optional. Hosting providers usually inject this automatically.
PORT=3000

# Request body limits. Repository import/file payloads can be larger than normal API requests.
JSON_REQUEST_LIMIT="1mb"
LARGE_JSON_REQUEST_LIMIT="25mb"

# SQLite database path. In production, point this at a persistent disk/volume path.
SQLITE_DB_PATH="./devassist.sqlite"
ALLOW_EPHEMERAL_SQLITE=false

# Required for signed authentication tokens. Use a long random value in shared or production environments.
JWT_SECRET="replace-with-a-long-random-secret"

# Optional admin seed. Local development uses these defaults if no override is provided.
ADMIN_USERNAME=devassist_admin
ADMIN_EMAIL=admin@devassist.local
ADMIN_PASSWORD=DevAssist@123456
DISABLE_DEV_ADMIN_SEED=false

# Optional GitHub OAuth credentials.
GITHUB_CLIENT_ID=your_github_oauth_client_id_here
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret_here
GITHUB_CALLBACK_URL="http://localhost:3000/api/auth/github/callback"

# Private GitHub imports can use this server token, or a one-time token entered in the import form.
GITHUB_PAT=your_github_pat_here
GITHUB_IMPORT_MAX_FILES=150
GITHUB_IMPORT_MAX_FILE_BYTES=150000

# Required for AI analysis, orchestration, knowledge-base Q&A, and generated docs/tests.
GROQ_API_KEY=your_groq_api_key_here
